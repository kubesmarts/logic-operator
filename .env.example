# Operator version and build configuration
VERSION=2.0.0-snapshot
IMAGE_TAG=2.0.0
PLATFORM_TAG=2.0.0

# Registry and image naming
REGISTRY=quay.io
ACCOUNT=kiegroup
OPERATOR_NAME=logic-operator

# Related images (pointing to existing Apache/KIE images)
RELATED_IMAGE_JOBS_SERVICE_POSTGRESQL=apache/incubator-kie-kogito-jobs-service-postgresql:latest
RELATED_IMAGE_JOBS_SERVICE_EPHEMERAL=apache/incubator-kie-kogito-jobs-service-ephemeral:latest
RELATED_IMAGE_DATA_INDEX_POSTGRESQL=apache/incubator-kie-kogito-data-index-postgresql:latest
RELATED_IMAGE_DATA_INDEX_EPHEMERAL=apache/incubator-kie-kogito-data-index-ephemeral:latest
RELATED_IMAGE_BASE_BUILDER=apache/incubator-kie-sonataflow-builder:latest
RELATED_IMAGE_DEVMODE=apache/incubator-kie-sonataflow-devmode:latest
RELATED_IMAGE_DB_MIGRATOR_TOOL=apache/incubator-kie-kogito-db-migrator:latest

# Image digest pinning tool (docker, podman, or skopeo)
PIN_IMAGE_SHA_BUNDLE_TOOL=docker
